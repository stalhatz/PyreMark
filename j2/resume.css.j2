{% macro tr(prop,default = "Undefined property") -%}
  {% if prop is defined -%}
    {{prop}}
  {%- else -%}
    {{default}}
  {%- endif %}
{%- endmacro %}

*{
  {# border : 1px solid red !important; #}
  box-sizing : border-box;
}

:root{
  --pageHeight: {{tr(styles.pageHeightInMM,"297")}}mm;
  --pageWidth: {{tr(styles.pageWidthInMM,"210")}}mm;
}

html{
  font-size: {{tr(styles.fontSize,"10.9px")}} ;
}

.canvas-container{
  font-size: {{tr(styles.fontSize,"10.9px")}} ;
  font-family: 'Montserrat', 'Fira Sans Extra Condensed' , "Futura","EB Garamond","Clarendon","Bodoni Moda","Libre Bodoni","Avenir","DIN","Akzidenz Grotesk","Frutiger","Univers","Sabon","Mrs Eaves","Meta","News Cycle",'Roboto Condensed', "Helvetica",sans-serif;
}

.page{
  display:flex;
  flex-flow:column;
  justify-content: space-between;
  width: var(--pageWidth);
  height: var(--pageHeight);
  background-color: white;
  box-shadow: 0 3px 8px -3px rgba(0, 0, 0, 0.7);
  margin-block: auto; /* for centering, feel free to use flexbox or some other method*/
  margin-bottom: 10mm;
  border: 1px solid rgba(0,0,0,0.2);
}

h1{
  font-size: 2.9rem;
  margin-bottom: 0.2rem;
}

p{
  font-weight: 300; /* Montserrat */
  line-height: 1.3; /* Montserrat */
}

.stronger{
  font-weight:600;
}

.svg-image{
  width: 15px;
}
.canvas-container {
  width: var(--pageWidth);
  margin: 0 auto;
}

.grid-element{
  display:grid;
  /* We'll try to keep for the time being a 1:6 ratio*/
  grid-template-columns: calc(var(--pageWidth) * 0.14) calc(var(--pageWidth) * 0.86);
}

.subgrid{
  display: grid;
  grid-template-columns: calc(var(--pageWidth) * 0.14) calc(var(--pageWidth) * 0.36) calc(var(--pageWidth) * 0.14) calc(var(--pageWidth) * 0.36);  
}

.titleName{
  display: flex;
  flex-direction:column;
  margin-left:3rem;
  margin-block:auto;
  width: min-content;
}

.titleName h1{
  padding-inline: 1.5rem;
  white-space: nowrap;
  text-align: center;
}

.titleName h2{
  margin-block: 0.1rem;
  text-align: center;
}

.pitch{
  background-color: rgb(220, 220, 220);
  padding-inline: 1rem;
  padding-block: 0.5rem;
  margin-block: 0.3rem;
  border-radius: 1rem;
  box-shadow: 1px 1px 1px black;
  font-style: italic;
  font-weight: 300;
  align-self: anchor-center;
  text-wrap: balance;
}

.details{
    display:grid;
    grid-template-columns: 5mm auto;
    /* border-right: 1px solid rgba(0, 0, 0, 0.3);
    margin-right:5mm; */
    padding-inline: 5mm;
    /* transform: rotate(10deg); */
}

.details-list{
  padding-inline: 5px;
  margin-block: auto;
  padding-right: 3mm;
  border-left: 1px solid rgba(0,0,0,0.3);
}

.details-list>div{
  margin-bottom: {{tr(styles.preambule_detailsBottomMargin,"0.5rem")}};
  display: flex;
  align-items: center;

}
.details-list>div p{
  margin:0;
  margin-inline-start: 1rem;
  white-space: nowrap;
}

.logo{
  background-size: cover;
  --size:1.05rem;
  width:var(--size);
  height:var(--size);
  margin-inline: 0.3rem;
  -webkit-print-color-adjust: exact;
  print-color-adjust: exact;
  opacity:0.99; /* Chromium bug showing blurred svgs */
  filter: brightness(0)
}

