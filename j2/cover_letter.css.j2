{% macro tr(prop,default = "Undefined property") -%}
{% if prop is mapping -%}
  {% if prop[lang]  is defined -%}
    {{ prop[lang] }}
  {%- else -%}
    {{ prop["def"] }}
  {%- endif %}
{%- else -%}
  {% if prop is defined -%}
    {{prop}}
  {%- else -%}
    {{default}}
  {%- endif %}
{%- endif %}
{%- endmacro %}

html{
  font-size: {{tr(styles.fontSize,"15px")}} ;
  font-family: 'Montserrat', 'Fira Sans Extra Condensed' , "Futura","EB Garamond","Clarendon","Bodoni Moda","Libre Bodoni","Avenir","DIN","Akzidenz Grotesk","Frutiger","Univers","Sabon","Mrs Eaves","Meta","News Cycle",'Roboto Condensed', "Helvetica",sans-serif;
}
h1{
  font-size: 3rem;
  margin-bottom: 0.2rem;
}

p{
  font-weight: 300; /* Montserrat */
  line-height: 1.3; /* Montserrat */
}

.receiverAddress{
    text-align: end;
}
.addresses{
    display: flex;
    justify-content: space-between;
}

.date{
    text-align: end;
}

.stronger{
  font-weight:800;
}

.text p {
  text-align: justify;
}

.canvas-container {
  margin: 0 auto; /* for centering, feel free to use flexbox or some other method*/
  box-sizing: border-box;
  padding-inline: 10px;
  padding-block: 20px;
  /* padding-inline: 1cm; 
  padding-top: 0.8cm;
  padding-bottom: 2cm; */
  width: 210mm;
  height: 297mm;
  background-color: white;
  box-shadow: 0 3px 8px -3px rgba(0, 0, 0, 0.7);
}


em{
  font-weight: 300;
}

@media print {
  @page { 
    margin: 1.2cm; 
    size: a4 portrait;
  }

  html {
    width: 210mm;
    height: 297mm;
    overflow: hidden;
  }

  body {
    margin: 0;
  }

  .canvas-container {
    width: 100%;
    box-shadow: none;
  }
}
