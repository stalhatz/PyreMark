.card-element h3{
  margin-block: 0.4rem;
  font-size: 1.05rem;
}

.card-element .text{
  flex-grow: 100;
  font-weight: 300; /* Montserrat */
  line-height: 1.3; /* Montserrat */

}

.card-element .title{
  flex-grow: 2;
}

.card-element .issuer-and-id{
  font-size: 0.8rem;
  display: flex;
  justify-content: space-between;
}

.card-element .divider {
    border: 0;
    height: 1px;
    background-color: #000000; /* Color of the line */
}

.card-date {
    width: 31px;
    height: 17px;
    top: -16px;
    left: 4px;
    background-color: white;
    border: 0.4mm black solid;
    position: absolute;
}

.card-element{
  display: flex;
  flex-direction: column;
  border: 0.4mm solid black;
  padding: 5px;
  /* width: 4cm; */
  justify-content: space-around;
  min-height: 140px;
  background-color: white;
  position: relative;
}

.card-wrapper{
  position: relative;
  flex: 1;
}

.card-container{
  margin-top: 25px;
  margin-bottom: 15px;
  gap: 2px;
}

.grid-element.card-container{
  display: flex;
  flex-direction: row;
  margin-right: 5px;
}