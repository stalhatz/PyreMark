.preambule{
  justify-content: space-between;
  align-items: center;
  display: flex;
  flex-direction: row;
}
.personal-info{
  display: flex;
  flex-direction: row;
  margin-left: auto;
}
.personal-info .details{
  margin-top: auto;
  max-width:5cm;
  margin-right: 2mm;
}

.personal-info .details p{
  margin-block: 1mm;
  text-align: left;
}

.personal-info .photo{
  margin-top: auto;
  box-shadow: 0 3px 8px -3px rgba(0, 0, 0, 0.4);
}


.profile-photo{
  max-width:3.5cm;
  width:100%;
  float: inline-end;
}

h2{
  font-size : 1.4rem;
}

h3{
  font-size : 1.1rem;
}

.cv-chapter{
  padding-top:1px;
  /*outline: 1px solid rgba(255,0,0,0.25);*/
}

.cv-chapter:first-child > h2 {
  margin-top: 0mm;
}

.cv-chapter > h2 {
  padding-top : 0mm;
  padding-bottom : 0mm;
  margin-top: 0mm;
  margin-bottom: 1mm;
  border-bottom: 1px solid rgba(0, 0, 0, 0.4);
}

.line-element{
  display: flex;
  flex-direction: row;
}

.rhs-element h3{
  margin-top:0;
  margin-bottom:0.0mm;
}

.rhs-element p{
  margin-top :0;
  margin-bottom: 2mm;
}

.rhs-element h3 + p{
  margin-top :0;
  margin-bottom: 1mm;
}

.grid-element.knowhow-container{
  display: flex;
  flex-direction: column;
  margin-right: 5px;
}

.grid-element.soft-skills-container{
  display: flex;
  flex-direction: column;
  margin-right: 5px;
  ul{
    display: flex;
    flex-direction: column;
    list-style: none;
    margin: 0;
    padding-left: 0;
  }
}

.grid-element:has(h3) .date{
  margin-top: 0.4mm;
}

.grid-element > *:only-child {
  grid-column: 1 / -1;
}

.taglist{
  margin-bottom: 1mm;
}

.taglist ul{
  display: flex;
  flex-wrap: wrap;
  row-gap: 0.5rem;
  list-style: none;
  margin: 0;
  padding-left: 0;
}

.taglist li{
  display:flex;
  align-items: anchor-center;
  padding-inline: 1mm;
  padding-block: 0.3mm;
  background-color: lightgray;
  border-radius: 7px;
  border: 0.4mm solid black;
  margin-right: 1mm;
}

.date:has(+ .taglist){
  padding-top: 0.7mm;
}

em{
  font-weight: 600;
}

@media print {
  @page { 
    margin : 0.0cm
    size: a4 portrait;
  }

  html {
    width: 210mm;
    height: 297mm;
    overflow: hidden;
  }

  body {
    margin: 0;
  }

  .page{
    box-shadow: none;
    border:none;
  }

  .canvas-container {
    width: 100%;
    box-shadow: none;
  }
}

{%- for cssTemplate in cssTemplates %}
