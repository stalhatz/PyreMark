.card-element h3{
  margin-block: 0.4rem;
  font-size: 1.05rem;
}

.card-element .text{
  flex-grow: 100;
  font-weight: 300; /* Montserrat */
  line-height: 1.3; /* Montserrat */

}

.card-element .title{
  flex-grow: 2;
}

.card-element .issuer-and-id{
  font-size: 0.8rem;
  display: flex;
  justify-content: space-between;
}

.card-element .divider {
    border: 0;
    height: 1px;
    background-color: #000000; /* Color of the line */
}

.card-date {
    padding-inline: 3px;
    height: 17px;
    top: -15px;
    left: 4px;
    background-color: white;
    border: var(--darkBorder);
    position: absolute;
}

.card-element{
  display: flex;
  flex-direction: column;
  border: var(--darkBorder);
  padding: 0.7rem;
  {# justify-content: space-around; #}
  min-height: 100%;
  background-color: white;
  position: relative;
  border-radius : 10px;
  box-shadow: var(--shadow);
}

.card-wrapper{
  position: relative;
  flex: 1;
}

.card-container{
  padding-top: 1.8rem;
  padding-bottom: 0.8rem;
  gap: 2px;
  display: flex;
  flex-direction: row;
  margin-right: 5px;
}