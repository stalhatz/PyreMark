{% macro tr(prop,default = "Undefined property") -%}
{% if prop is mapping -%}
  {% if prop[lang]  is defined -%}
    {{ prop[lang] }}
  {%- else -%}
    {{ prop["def"] }}
  {%- endif %}
{%- else -%}
  {% if prop is defined -%}
    {{prop}}
  {%- else -%}
    {{default}}
  {%- endif %}
{%- endif %}
{%- endmacro %}
<!DOCTYPE html>
<html lang="{{lang}}">

<head>
    <meta charset="utf-8">
    <title>Stavros Alchatzidis CV page</title>
</head>

  <link rel="stylesheet" type="text/css" href="{{tr(styles.cssfile,"./css/styles.css")}}"/>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family={{tr(styles.gFontFamily)}}:ital,wght@0,300;0,500;0,800;1,200;1,500&display=swap" rel="stylesheet">
  <script type="text/javascript" src="{{tr(script.jsfile,"./js/script.js")}}"></script>
  <body>
    <div class="canvas-container">
      {%- for sectionName in sections %}
        {% if data[sectionName] is defined -%}
          {% with chapterName=sectionName, chapter=data[sectionName] %}
            
            {% if chapter.title is defined -%}
              <div class="cv-chapter {{chapterName}}">
              <h2> {{ tr(chapter.title) }} </h2>
              {% if chapter.classes is defined -%}
                <div class="grid-element {{chapter.classes}}">
              {%- else -%}
                <div class="grid-element">
              {%- endif %}
              {% include "./j2/" + data[sectionName].template %}
              </div>
              </div>
            {%- else -%}
              {% include "./j2/" + data[sectionName].template %}
            {%- endif %}
          {% endwith %}
        {%- endif %}
      {% endfor -%}
    </div>
  </body>
</html>
